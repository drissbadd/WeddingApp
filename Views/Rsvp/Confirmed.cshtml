@{
    Layout = null;
    var name = ViewBag.GuestName as string ?? "Cher(e) invité(e)";
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Confirmation — Zineb & Driss</title>
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Playfair+Display:wght@400;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            min-height: 100vh;
            font-family: 'Lato', sans-serif;
            background: linear-gradient(135deg, #155724 0%, #28a745 60%, #20c997 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .card {
            background: white;
            border-radius: 24px;
            max-width: 440px;
            width: 100%;
            text-align: center;
            padding: 3rem 2rem;
            box-shadow: 0 20px 60px rgba(0,0,0,0.25);
        }
        .big-check {
            font-size: 5rem;
            display: block;
            margin-bottom: 1rem;
            animation: pop 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97);
        }
        @@keyframes pop {
            0%   { transform: scale(0); }
            60%  { transform: scale(1.2); }
            100% { transform: scale(1); }
        }
        h1 { font-family: 'Playfair Display', serif; color: #155724; margin-bottom: 0.5rem; }
        .guest-name { font-family: 'Great Vibes', cursive; font-size: 2rem; color: #28a745; }
        p { color: #555; margin-top: 0.75rem; line-height: 1.6; }
        .couple { font-family: 'Great Vibes', cursive; font-size: 1.6rem; color: #C9184A; margin-top: 1.5rem; }
        .confetti { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: -1; }
        .confetti span {
            position: absolute;
            font-size: 1.5rem;
            animation: confetti-fall linear infinite;
            opacity: 0;
        }
        @@keyframes confetti-fall {
            0%   { transform: translateY(-20px) rotate(0deg); opacity: 1; }
            100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
        }
    </style>
</head>
<body>
<div class="confetti" id="confetti"></div>
<div class="card">
    <span class="big-check">✅</span>
    <h1>Merci !</h1>
    <div class="guest-name">@name</div>
    <p>
        Votre présence est confirmée avec bonheur.<br>
        Nous avons hâte de partager ce moment inoubliable avec vous ! 🎉
    </p>
    <div class="couple">Zineb & Driss 💕</div>
</div>
<script>
const emojis = ['🎉','🌸','💕','✨','🥂','💍','❤️','🌷'];
const c = document.getElementById('confetti');
for (let i = 0; i < 25; i++) {
    const el = document.createElement('span');
    el.textContent = emojis[Math.floor(Math.random() * emojis.length)];
    el.style.left = Math.random() * 100 + 'vw';
    el.style.animationDuration = (4 + Math.random() * 6) + 's';
    el.style.animationDelay = (Math.random() * 5) + 's';
    c.appendChild(el);
}
</script>
</body>
</html>
