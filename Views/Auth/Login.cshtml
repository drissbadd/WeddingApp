@{
    Layout = null;
    ViewData["Title"] = "Connexion";
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Connexion - Mariage Zineb & Driss</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #f8f0f2, #fce4ec);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
            max-width: 400px;
            width: 100%;
        }
        .login-header {
            background: linear-gradient(135deg, #c2185b, #e91e8c);
            color: white;
            border-radius: 16px 16px 0 0;
            padding: 2rem;
            text-align: center;
        }
        .login-header h4 { margin: 0; font-weight: 300; letter-spacing: 1px; }
        .login-header p { margin: 0.5rem 0 0; opacity: 0.85; font-size: 0.9rem; }
        .btn-login {
            background: linear-gradient(135deg, #c2185b, #e91e8c);
            border: none;
            color: white;
            width: 100%;
            padding: 0.75rem;
            border-radius: 8px;
            font-size: 1rem;
        }
        .btn-login:hover { opacity: 0.9; color: white; }
    </style>
</head>
<body>
    <div class="login-card card">
        <div class="login-header">
            <h4>Zineb & Driss</h4>
            <p>Espace Administration</p>
        </div>
        <div class="card-body p-4">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            <form method="post" action="/auth/login">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Identifiant</label>
                    <input type="text" name="username" class="form-control" required autofocus />
                </div>
                <div class="mb-4">
                    <label class="form-label">Mot de passe</label>
                    <input type="password" name="password" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-login">Se connecter</button>
            </form>
        </div>
    </div>
</body>
</html>
