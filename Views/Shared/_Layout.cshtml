<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Mariage Zineb & Driss</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/wedding.css" />
</head>
<body>

<div class="d-flex" id="wrapper">
    <!-- Sidebar -->
    <nav id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-heart">♥</div>
            <div class="brand-names">Zineb & Driss</div>
            <div class="brand-subtitle">Gestion du Mariage</div>
        </div>
        <ul class="sidebar-nav">
            <li class="nav-section">Navigation</li>
            <li>
                <a asp-controller="Home" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <i class="bi bi-grid-1x2-fill"></i> Tableau de Bord
                </a>
            </li>
            <li>
                <a asp-controller="Guests" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Guests" ? "active" : "")">
                    <i class="bi bi-people-fill"></i> Invités
                </a>
            </li>
            <li>
                <a asp-controller="Guests" asp-action="Create">
                    <i class="bi bi-person-plus-fill"></i> Ajouter un Invité
                </a>
            </li>
            <li>
                <a asp-controller="Guests" asp-action="ExportCsv">
                    <i class="bi bi-file-earmark-spreadsheet-fill"></i> Exporter CSV
                </a>
            </li>
        </ul>
        <div class="sidebar-footer">
            <small>Avec amour ♥</small>
        </div>
    </nav>

    <!-- Content -->
    <div id="page-content">
        <header class="top-header">
            <button class="btn btn-link sidebar-toggle" id="sidebarToggle">
                <i class="bi bi-list fs-4"></i>
            </button>
            <div class="header-title">@ViewData["Title"]</div>
            <div class="header-actions">
                <a asp-controller="Guests" asp-action="Create" class="btn btn-wedding btn-sm">
                    <i class="bi bi-person-plus"></i> Ajouter
                </a>
            </div>
        </header>

        <main class="main-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show wedding-alert" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show wedding-alert" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.getElementById('sidebarToggle')?.addEventListener('click', () => {
        document.getElementById('wrapper').classList.toggle('sidebar-collapsed');
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
