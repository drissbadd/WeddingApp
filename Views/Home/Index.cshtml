@model DashboardViewModel
@{
    ViewData["Title"] = "Tableau de Bord";
}

<!-- Countdown -->
<div class="wedding-card mb-4 p-4 text-center" style="background: linear-gradient(135deg, #590D22, #C9184A); color: white; border-radius: 16px;">
    <div style="font-family: 'Playfair Display', serif; font-size: 1rem; letter-spacing: 4px; opacity: 0.85; margin-bottom: 0.5rem;">MARIAGE — 9 MAI 2026</div>
    <div style="font-size: 0.85rem; opacity: 0.7; margin-bottom: 1.2rem;">La Maison Blanche, Rabat</div>
    <div class="d-flex justify-content-center gap-3">
        <div style="background: rgba(255,255,255,0.15); border-radius: 12px; padding: 0.8rem 1.2rem; min-width: 80px;">
            <div id="dash-days" style="font-size: 2.2rem; font-weight: 700; line-height: 1;">–</div>
            <div style="font-size: 0.65rem; letter-spacing: 2px; opacity: 0.8; margin-top: 2px;">JOURS</div>
        </div>
        <div style="background: rgba(255,255,255,0.15); border-radius: 12px; padding: 0.8rem 1.2rem; min-width: 80px;">
            <div id="dash-hours" style="font-size: 2.2rem; font-weight: 700; line-height: 1;">–</div>
            <div style="font-size: 0.65rem; letter-spacing: 2px; opacity: 0.8; margin-top: 2px;">HEURES</div>
        </div>
        <div style="background: rgba(255,255,255,0.15); border-radius: 12px; padding: 0.8rem 1.2rem; min-width: 80px;">
            <div id="dash-min" style="font-size: 2.2rem; font-weight: 700; line-height: 1;">–</div>
            <div style="font-size: 0.65rem; letter-spacing: 2px; opacity: 0.8; margin-top: 2px;">MIN</div>
        </div>
        <div style="background: rgba(255,255,255,0.15); border-radius: 12px; padding: 0.8rem 1.2rem; min-width: 80px;">
            <div id="dash-sec" style="font-size: 2.2rem; font-weight: 700; line-height: 1;">–</div>
            <div style="font-size: 0.65rem; letter-spacing: 2px; opacity: 0.8; margin-top: 2px;">SEC</div>
        </div>
    </div>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card position-relative">
            <div class="stat-icon"><i class="bi bi-people"></i></div>
            <div class="stat-number">@Model.TotalGuests</div>
            <div class="stat-label">Total Invités</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card green position-relative">
            <div class="stat-icon" style="color:#28a745"><i class="bi bi-check-circle"></i></div>
            <div class="stat-number" style="color:#28a745">@Model.Confirmed</div>
            <div class="stat-label">Confirmés</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card gray position-relative">
            <div class="stat-icon" style="color:#6c757d"><i class="bi bi-hourglass-split"></i></div>
            <div class="stat-number" style="color:#6c757d">@Model.Pending</div>
            <div class="stat-label">En Attente</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card gold position-relative">
            <div class="stat-icon" style="color:#D4AF37"><i class="bi bi-star"></i></div>
            <div class="stat-number" style="color:#D4AF37">@Model.TotalAttending</div>
            <div class="stat-label">Présences totales (+ accompagnants)</div>
        </div>
    </div>
</div>

<!-- Second stats row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="wedding-card p-3 text-center">
            <div class="fs-3 mb-1" style="color:var(--rose)"><i class="bi bi-whatsapp"></i></div>
            <div class="fw-bold fs-5">@Model.InvitationsSent</div>
            <div class="text-muted small">Invitations Envoyées</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="wedding-card p-3 text-center">
            <div class="fs-3 mb-1" style="color:#dc3545"><i class="bi bi-x-circle"></i></div>
            <div class="fw-bold fs-5">@Model.Declined</div>
            <div class="text-muted small">Déclinés</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="wedding-card p-3 text-center">
            <div class="fs-3 mb-1" style="color:var(--gold)"><i class="bi bi-envelope-check"></i></div>
            <div class="fw-bold fs-5">@(Model.TotalGuests - Model.InvitationsSent)</div>
            <div class="text-muted small">Pas encore invités</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="wedding-card p-3 text-center">
            <div class="fs-3 mb-1" style="color:var(--rose)"><i class="bi bi-percent"></i></div>
            <div class="fw-bold fs-5">
                @(Model.InvitationsSent > 0 ? $"{(Model.Confirmed * 100 / Model.InvitationsSent)}%" : "–")
            </div>
            <div class="text-muted small">Taux de confirmation</div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-3 mb-4">
    <div class="col-lg-5">
        <div class="wedding-card">
            <div class="card-header">Statut des RSVP</div>
            <div class="p-3" style="height:260px;">
                <canvas id="rsvpChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="wedding-card">
            <div class="card-header"><i class="bi bi-people me-2"></i>Confirmés par Famille</div>
            <div class="p-3">
                @foreach (var cat in Model.ByCategoryStatus)
                {
                    var total = cat.Value.Confirmed + cat.Value.Pending + cat.Value.Declined;
                    var pct = total > 0 ? (cat.Value.Confirmed * 100 / total) : 0;
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fw-semibold">@cat.Key</span>
                            <span class="text-muted small">
                                <span class="text-success fw-bold">@cat.Value.Confirmed ✓</span>
                                &nbsp;·&nbsp; @cat.Value.Pending ⏳
                                &nbsp;·&nbsp; <span class="text-danger">@cat.Value.Declined ✗</span>
                                &nbsp;/ @total
                            </span>
                        </div>
                        <div class="progress" style="height: 10px; border-radius: 8px;">
                            <div class="progress-bar bg-success" style="width: @pct%; border-radius: 8px;"></div>
                        </div>
                    </div>
                }
                @if (!Model.ByCategoryStatus.Any())
                {
                    <div class="text-center text-muted py-4">Aucun invité pour l'instant</div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Recent RSVPs -->
@if (Model.RecentRsvps.Any())
{
    <div class="wedding-card">
        <div class="card-header"><i class="bi bi-clock-history me-2"></i>RSVP Récents</div>
        <div class="table-responsive">
            <table class="table wedding-table mb-0">
                <thead>
                    <tr>
                        <th>Invité</th>
                        <th>Statut</th>
                        <th>Catégorie</th>
                        <th>+1</th>
                        <th>Le</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in Model.RecentRsvps)
                    {
                        <tr>
                            <td class="fw-semibold">@g.Name</td>
                            <td>
                                @if (g.Status == RsvpStatus.Confirmed)
                                { <span class="badge-confirmed">✓ Confirmé</span> }
                                else if (g.Status == RsvpStatus.Declined)
                                { <span class="badge-declined">✗ Décliné</span> }
                                else
                                { <span class="badge-pending">⏳ En attente</span> }
                            </td>
                            <td><span class="badge-cat cat-@g.Category">@g.Category</span></td>
                            <td>@(string.IsNullOrEmpty(g.PlusOneName) ? "–" : g.PlusOneName)</td>
                            <td class="text-muted small">@g.RsvpAt?.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-hourglass fs-1 d-block mb-2" style="opacity:.3"></i>
        Aucun RSVP reçu pour l'instant. Envoyez vos invitations !
    </div>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
// Countdown
const weddingDate = new Date('2026-05-09T18:00:00');
function updateDashCountdown() {
    const diff = weddingDate - new Date();
    if (diff <= 0) return;
    document.getElementById('dash-days').textContent  = Math.floor(diff / 86400000);
    document.getElementById('dash-hours').textContent = String(Math.floor((diff % 86400000) / 3600000)).padStart(2,'0');
    document.getElementById('dash-min').textContent   = String(Math.floor((diff % 3600000) / 60000)).padStart(2,'0');
    document.getElementById('dash-sec').textContent   = String(Math.floor((diff % 60000) / 1000)).padStart(2,'0');
}
updateDashCountdown();
setInterval(updateDashCountdown, 1000);

// RSVP Donut Chart
new Chart(document.getElementById('rsvpChart'), {
    type: 'doughnut',
    data: {
        labels: ['Confirmés', 'Déclinés', 'En attente'],
        datasets: [{ data: [@Model.Confirmed, @Model.Declined, @Model.Pending],
            backgroundColor: ['#28a745','#dc3545','#ffc107'],
            borderWidth: 0, hoverOffset: 8 }]
    },
    options: { responsive: true, maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { padding: 12, font: { size: 12 } } } } }
});
</script>
}
