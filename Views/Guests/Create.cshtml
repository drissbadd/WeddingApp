@model Guest
@{
    ViewData["Title"] = "Ajouter un Invité";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="wedding-card">
            <div class="card-header">
                <i class="bi bi-person-plus me-2"></i>Nouvel Invité
            </div>
            <div class="p-4 wedding-form">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" placeholder="Ex: Ahmed Benali" autofocus />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+212612345678" />
                            <div class="form-text">Inclure le code pays (ex: +212 pour le Maroc)</div>
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Category" class="form-label"></label>
                            <select asp-for="Category" asp-items="Html.GetEnumSelectList<GuestCategory>()" class="form-select"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MealPreference" class="form-label"></label>
                            <select asp-for="MealPreference" asp-items="Html.GetEnumSelectList<MealPreference>()" class="form-select"></select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TableNumber" class="form-label"></label>
                            <input asp-for="TableNumber" class="form-control" type="number" min="1" max="200" placeholder="Optionnel" />
                            <span asp-validation-for="TableNumber" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 d-flex align-items-center pt-3">
                            <div class="form-check form-switch">
                                <input asp-for="HasPlusOne" class="form-check-input" type="checkbox" role="switch" style="width:3em;height:1.5em">
                                <label asp-for="HasPlusOne" class="form-check-label ms-2">Autoriser un accompagnant (+1)</label>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label">Notes</label>
                            <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Remarques particulières..."></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-wedding px-4">
                            <i class="bi bi-person-check me-1"></i>Ajouter l'Invité
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
