@model Guest
@{
    ViewData["Title"] = $"Modifier — {Model.Name}";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="wedding-card">
            <div class="card-header">
                <i class="bi bi-pencil me-2"></i>Modifier : @Model.Name
            </div>
            <div class="p-4 wedding-form">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Category" class="form-label"></label>
                            <select asp-for="Category" asp-items="Html.GetEnumSelectList<GuestCategory>()" class="form-select"></select>
                        </div>
                        <div class="col-md-6 d-flex align-items-center pt-3">
                            <div class="form-check form-switch">
                                <input asp-for="HasPlusOne" class="form-check-input" type="checkbox" role="switch" style="width:3em;height:1.5em">
                                <label asp-for="HasPlusOne" class="form-check-label ms-2">Autoriser un accompagnant (+1)</label>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label">Notes</label>
                            <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                        </div>

                        <!-- RSVP Info (read-only) -->
                        @if (Model.Status != RsvpStatus.Pending)
                        {
                            <div class="col-12">
                                <div class="alert alert-info mb-0">
                                    <strong>RSVP :</strong>
                                    @(Model.Status == RsvpStatus.Confirmed ? "✓ Confirmé" : "✗ Décliné")
                                    le @Model.RsvpAt?.ToString("dd/MM/yyyy à HH:mm")
                                    @if (!string.IsNullOrEmpty(Model.PlusOneName))
                                    { <span> — accompagnant : <strong>@Model.PlusOneName</strong></span> }
                                </div>
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-wedding px-4">
                            <i class="bi bi-save me-1"></i>Enregistrer
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
